{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strategic-framework.dev/jgdl/v1.0.0/schema.json",
  "title": "JGDL v1.0.0 — JSON Game Description Language",
  "description": "Serialization contract for Strategic toolkit. Every implementation (Julia, Rust, TypeScript) must accept and produce documents that validate against this schema.",
  "type": "object",
  "required": ["version", "world"],
  "properties": {
    "version": { "type": "string", "const": "1.0.0" },
    "world": {
      "type": "object",
      "required": ["id", "players", "actions", "structure", "payoffs", "provenance"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Content hash of the world, excluding this field."
        },
        "metadata": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" },
            "chapter_references": {
              "type": "array",
              "items": { "type": "string" }
            },
            "created": { "type": "string", "format": "date-time" }
          }
        },
        "players": {
          "type": "array",
          "items": { "$ref": "#/$defs/Player" }
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/Action" }
        },
        "structure": { "$ref": "#/$defs/Structure" },
        "payoffs": { "$ref": "#/$defs/Payoffs" },
        "traits": {
          "type": "array",
          "items": { "$ref": "#/$defs/Trait" }
        },
        "initial_state": { "$ref": "#/$defs/State" },
        "provenance": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProvenanceNode" }
        },
        "open_world": { "$ref": "#/$defs/OpenWorld" },
        "hedges": {
          "type": "array",
          "items": { "$ref": "#/$defs/Hedge" }
        }
      }
    }
  },
  "$defs": {
    "Player": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["rational", "bounded_rational", "human_oracle", "llm_driven", "shadow"]
        },
        "parameters": {
          "type": "object",
          "properties": {
            "rationality_factor": { "type": "number", "minimum": 0, "maximum": 1 },
            "discount_rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "risk_aversion": { "type": "number" }
          }
        }
      }
    },
    "Action": {
      "type": "object",
      "required": ["id", "player_id"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "player_id": { "type": "string" },
        "cost": { "$ref": "#/$defs/Expression" },
        "observability": {
          "type": "string",
          "enum": ["public", "private", "delayed"]
        }
      }
    },
    "Structure": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["simultaneous", "sequential", "repeated", "stochastic"]
        },
        "order": { "type": "array", "items": { "type": "string" } },
        "information_sets": { "type": "array" },
        "repetitions": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "const": "infinite" }
          ]
        },
        "discount_factor": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "Payoffs": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["terminal_matrix", "function", "cached"]
        },
        "matrix": { "type": "object" },
        "function": { "$ref": "#/$defs/Expression" },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Trait": {
      "type": "object",
      "required": ["id", "type", "chapter"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "Commitment",
            "CredibleThreat",
            "BurnedBridge",
            "MixedStrategy",
            "Brinkmanship",
            "CoordinationDevice",
            "VotingRule",
            "BargainingProtocol",
            "TournamentIncentive",
            "BayesianBelief",
            "LearningRule"
          ]
        },
        "chapter": { "type": "string" },
        "applies_to": {
          "type": "string",
          "enum": ["player", "game", "payoff", "action"]
        },
        "parameters": { "type": "object" }
      }
    },
    "State": {
      "type": "object",
      "properties": {
        "variables": { "type": "object" },
        "history": { "type": "array" },
        "current_player": { "type": ["string", "null"] },
        "round": { "type": "integer", "minimum": 0 }
      }
    },
    "ProvenanceNode": {
      "type": "object",
      "required": ["operation", "chapter_ref", "parent_id", "timestamp", "author"],
      "properties": {
        "operation": { "type": "string" },
        "chapter_ref": { "type": "string" },
        "theoretical_origin": { "type": "string" },
        "rationale": { "type": "string" },
        "parent_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "author": {
          "type": "string",
          "enum": ["user", "llm", "system"]
        }
      }
    },
    "OpenWorld": {
      "type": "object",
      "properties": {
        "emergence_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "unknown_player_pool": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["parametric", "DirichletProcess"] },
            "concentration_parameter": { "type": "number" }
          }
        },
        "shadow_player": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "surprise_weight": { "type": "number" }
          }
        }
      }
    },
    "Hedge": {
      "type": "object",
      "required": ["id", "trigger", "payoff_profile"],
      "properties": {
        "id": { "type": "string" },
        "trigger": { "$ref": "#/$defs/Expression" },
        "payoff_profile": { "type": "object" },
        "cost": { "type": "number" },
        "optionality_value": { "type": "number" },
        "chapter_reference": { "type": "string" }
      }
    },
    "Expression": {
      "type": "string",
      "description": "Safe expression in a restricted Julia-compatible subset. See docs/expression-language.md for grammar."
    }
  }
}
